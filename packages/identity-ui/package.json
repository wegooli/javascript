{
  "name": "@wegooli/identity-ui",
  "version": "1.0.4",
  "description": "Pre-built UI components for platform identity — SignIn, SignUp, UserProfile, OrgSwitcher",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tailwind.preset": "./tailwind.preset.js",
    "./tailwind.preset.js": "./tailwind.preset.js"
  },
  "files": [
    "dist",
    "tailwind.preset.js"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@wegooli/identity-react": "workspace:*"
  },
  "dependencies": {
    "@wegooli/identity-types": "workspace:*",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jsdom": "^25.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wegooli/javascript.git",
    "directory": "packages/identity-ui"
  },
  "homepage": "https://github.com/wegooli/javascript/tree/main/packages/identity-ui#readme",
  "bugs": "https://github.com/wegooli/javascript/issues",
  "keywords": [
    "identity",
    "auth",
    "authentication",
    "react",
    "ui",
    "oidc",
    "components",
    "SignIn",
    "SignUp"
  ]
}
