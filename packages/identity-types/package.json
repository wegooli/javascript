{
  "name": "@wegooli/identity-types",
  "version": "0.1.0",
  "description": "공유 TypeScript 타입 — JWT 클레임, API 응답, ERD 엔티티",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wegooli/javascript.git",
    "directory": "packages/identity-types"
  },
  "homepage": "https://github.com/wegooli/javascript/tree/main/packages/identity-types#readme",
  "bugs": "https://github.com/wegooli/javascript/issues",
  "keywords": ["identity", "auth", "authentication", "zitadel", "oidc", "types", "typescript"]
}
